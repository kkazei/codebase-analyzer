APP_NAME=Codebase Analyzer API
DEBUG=false
FRONTEND_ORIGIN=http://localhost:5173

PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
