GITHUB_TOKEN=
INGEST_MAX_REPO_MB=200
INGEST_CHUNK_SIZE=1000
INGEST_CHUNK_OVERLAP=200
INGEST_BATCH_SIZE=16
INGEST_EMBED_TIMEOUT_SEC=120
